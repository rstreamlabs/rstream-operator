{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "pull-request-header": "New release created",
  "packages": {
    ".": {
      "release-type": "simple",
      "include-v-in-tag": true,
      "extra-files": [
        {
          "type": "yaml",
          "path": "charts/rstream-operator/Chart.yaml",
          "jsonpath": "$.version"
        },
        {
          "type": "yaml",
          "path": "charts/rstream-operator/Chart.yaml",
          "jsonpath": "$.appVersion"
        }
      ]
    }
  }
}
